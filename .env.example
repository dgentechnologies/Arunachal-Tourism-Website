# ─────────────────────────────────────────────────────────────────────────────
# ARUNACHAL EXPLORE — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# For local development: copy this file to .env.local and fill in the values.
# For production: add every variable to Vercel → Project Settings → Environment
# Variables. Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://apt-website-v1.vercel.app

# ── Google / Gemini AI (server-side only) ─────────────────────────────────────
# Get from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Firebase Client SDK ───────────────────────────────────────────────────────
# Safe to expose to the browser (NEXT_PUBLIC_ prefix).
# Copy from: Firebase Console → Project Settings → General → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firestore Database IDs ────────────────────────────────────────────────────
# DB1 — Enterprise: hotels, vehicles, bookings, tour operators (DEFAULT database)
NEXT_PUBLIC_FIRESTORE_DB_ENTERPRISE=default
# DB2 — Users: user profiles, saved trips, permit applications
NEXT_PUBLIC_FIRESTORE_DB_USERS=arunachal-explore-users
# DB3 — CMS: circuits, activities, festivals, emergency contacts, notices
NEXT_PUBLIC_FIRESTORE_DB_CMS=arunachal-explore-cms

# ── Firebase Admin SDK (SERVER-ONLY — never add NEXT_PUBLIC_ prefix) ──────────
# Get from: Firebase Console → Project Settings → Service Accounts →
#           Generate new private key → download JSON → copy the three fields below.
# In Vercel, paste the private key exactly as-is (including \n line breaks).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Mobile App API ────────────────────────────────────────────────────────────
# Bearer token for /api/mobile-app — generate with: openssl rand -hex 32
MOBILE_APP_SECRET=your-strong-random-secret-here

# ── Payments (uncomment when integrating) ────────────────────────────────────
# Razorpay — INR domestic bookings
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Stripe — foreign card payments
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
